{
  "name": "stitchflow",
  "version": "1.0.0",
  "description": "StitchFlow CRM/ERP для швейного цеха",
  "scripts": {
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "npm install --prefix backend && node backend/src/server.js",
